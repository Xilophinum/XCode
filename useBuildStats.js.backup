// Composable for managing project build statistics
export default function useBuildStats() {
  const projectStats = ref(new Map())
  const isLoading = ref(false)

  // Load build stats for a project
  const loadProjectStats = async (projectId) => {
    if (!projectId) return null
    
    try {
      isLoading.value = true
      const stats = await $fetch(`/api/projects/${projectId}/build-stats`)
      projectStats.value.set(projectId, stats)
      return stats
    } catch (error) {
      console.error('Failed to load build stats:', error)
      // Return default stats on error
      const defaultStats = {
        summary: { successRate: 1, lastStatus: 'success', source: 'default' },
        colors: {
          health: {
            bg: 'bg-green-50 dark:bg-green-900/20',
            hover: 'hover:bg-green-100 dark:hover:bg-green-800/30',
            icon: 'text-green-600 dark:text-green-400',
            border: 'border-green-200 dark:border-green-600'
          },
          menu: {
            menu: 'bg-white dark:bg-gray-800',
            deleteButton: 'text-red-600 dark:text-red-400',
            moveButton: 'text-gray-700 dark:text-gray-300'
          }
        }
      }
      projectStats.value.set(projectId, defaultStats)
      return defaultStats
    } finally {
      isLoading.value = false
    }
  }

  // Load stats for multiple projects
  const loadMultipleProjectStats = async (projectIds) => {
    const promises = projectIds.map(id => loadProjectStats(id))
    await Promise.all(promises)
  }

  // Record a build result
  const recordBuildResult = async (projectId, status, message = '', logs = [], duration = 0) => {
    try {
      const result = await $fetch(`/api/projects/${projectId}/build-stats`, {
        method: 'POST',
        body: {
          type: 'build',
          status,
          message,
          logs,
          duration
        }
      })
      
      // Update local cache
      const currentStats = projectStats.value.get(projectId) || {}
      projectStats.value.set(projectId, {
        ...currentStats,
        summary: result.summary,
        colors: result.colors
      })
      
      return result
    } catch (error) {
      console.error('Failed to record build result:', error)
      return null
    }
  }

  // Record a terminal log
  const recordTerminalLog = async (projectId, level, message, command = null) => {
    try {
      const result = await $fetch(`/api/projects/${projectId}/build-stats`, {
        method: 'POST',
        body: {
          type: 'terminal',
          level,
          message,
          command
        }
      })
      
      // Update local cache
      const currentStats = projectStats.value.get(projectId) || {}
      projectStats.value.set(projectId, {
        ...currentStats,
        summary: result.summary,
        colors: result.colors
      })
      
      return result
    } catch (error) {
      console.error('Failed to record terminal log:', error)
      return null
    }
  }

  // Get cached stats for a project
  const getProjectStats = (projectId) => {
    return projectStats.value.get(projectId)
  }

  // Get project health colors
  const getProjectColors = (projectId) => {
    const stats = projectStats.value.get(projectId)
    return stats?.colors?.health || {
      bg: 'bg-green-50 dark:bg-green-900/20',
      hover: 'hover:bg-green-100 dark:hover:bg-green-800/30',
      icon: 'text-green-600 dark:text-green-400',
      border: 'border-green-200 dark:border-green-600'
    }
  }

  // Get project menu colors
  const getProjectMenuColors = (projectId) => {
    const stats = projectStats.value.get(projectId)
    return stats?.colors?.menu || {
      menu: 'bg-white dark:bg-gray-800',
      deleteButton: 'text-red-600 dark:text-red-400',
      moveButton: 'text-gray-700 dark:text-gray-300'
    }
  }

  // Get health status text
  const getHealthStatus = (projectId) => {
    const stats = projectStats.value.get(projectId)
    if (!stats) return 'Unknown'
    
    const { successRate, lastStatus, source } = stats.summary
    
    if (successRate >= 0.8) return 'Healthy'
    if (successRate >= 0.6) return 'Warning'
    if (successRate >= 0.3) return 'Issues'
    return 'Critical'
  }

  // Convenience methods for common terminal log levels
  const logInfo = (projectId, message, command = null) => 
    recordTerminalLog(projectId, 'info', message, command)
  
  const logWarning = (projectId, message, command = null) => 
    recordTerminalLog(projectId, 'warn', message, command)
  
  const logError = (projectId, message, command = null) => 
    recordTerminalLog(projectId, 'error', message, command)
  
  const logSuccess = (projectId, message, command = null) => 
    recordTerminalLog(projectId, 'success', message, command)

  return {
    // State
    projectStats: readonly(projectStats),
    isLoading: readonly(isLoading),
    
    // Methods
    loadProjectStats,
    loadMultipleProjectStats,
    recordBuildResult,
    recordTerminalLog,
    getProjectStats,
    getProjectColors,
    getProjectMenuColors,
    getHealthStatus,
    
    // Convenience methods
    logInfo,
    logWarning,
    logError,
    logSuccess
  }
}